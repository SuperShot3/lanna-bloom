# Copy to .env.local and fill in values. In Vercel, add these in Project Settings → Environment Variables.

# Google Tag Manager (client-side). GTM is the only analytics transport and only loads in production.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Microsoft Clarity (session replay / heatmaps). Only loads in production when set.
# NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# GA4 Measurement Protocol: when an order is marked paid (admin or Stripe webhook), send purchase event to GA4.
# Get these from GA4 Admin → Data Streams → your web stream → Measurement Protocol API secrets.
# Required for server-side "mark as paid → GA4 purchase" to work.
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_MEASUREMENT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GA4_MP_DEBUG=true   (optional; use GA4 debug endpoint to validate without counting)

# LINE (choose one approach):
# • Personal LINE account: set NEXT_PUBLIC_LINE_OA_ADD_FRIEND_LINK to your shareable link (e.g. https://line.me/ti/p/xxxx or https://lin.ee/xxxx). Both header "LINE" and "Order via LINE" use this link.
# • Official Account: set NEXT_PUBLIC_LINE_OA_ID=@youroaid; optionally set NEXT_PUBLIC_LINE_OA_ADD_FRIEND_LINK to override (e.g. https://lin.ee/xxxx).
# NEXT_PUBLIC_LINE_OA_ADD_FRIEND_LINK=https://line.me/ti/p/xxxx
# NEXT_PUBLIC_LINE_OA_ID=@lannabloom

# OpenClaw / agent: shared secret for /api/agent/line/* (Bearer). Generate a long random string.
# LINE_AGENT_SECRET=

# LINE Messaging API channel access token — configure on the OpenClaw/agent host only (agent sends LINE pushes).
# Do not put LINE_CHANNEL_ACCESS_TOKEN on the Next.js website.

# App URL for the order details link sent in chat (e.g. WhatsApp). Set to your live site URL (e.g. custom domain). If unset on Vercel, the link uses VERCEL_URL (*.vercel.app). Required so the link works when the user clicks it.
# NEXT_PUBLIC_APP_URL=https://www.your-shop.com

# Orders: Supabase is single source of truth. See docs/ORDERS_SUPABASE.md
# ORDERS_PRIMARY_STORE=supabase   (default when Supabase configured)
# ORDERS_READ_FALLBACK=none      (default: no Blob fallback)

# Blob: only if ORDERS_READ_FALLBACK=blob (legacy migration fallback)
# BLOB_READ_WRITE_TOKEN=...

# Order notification email (Resend). Add domain lannabloom.shop in Resend, set SPF/DKIM in Porkbun, then use From: orders@lannabloom.shop.
# RESEND_API_KEY=re_xxxx
# ORDERS_NOTIFY_EMAIL=polovnikov.k.v@gmail.com
# ORDERS_FROM_EMAIL=Lanna Bloom Orders <orders@lannabloom.shop>

# Newsletter: notification when someone subscribes. Uses RESEND_API_KEY and ORDERS_FROM_EMAIL.
# NEWSLETTER_NOTIFY_EMAIL=your@email.com   (recipient; can be same as ORDERS_NOTIFY_EMAIL)

# Stripe (optional). Same env var names are used in test and live; only the VALUES change per Vercel environment.
# For local webhook testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Use the test webhook secret from `stripe listen` locally, and the real endpoint secret from the Stripe Dashboard on Vercel.
# STRIPE_SECRET_KEY=sk_test_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Admin (RBAC with NextAuth). Required for /admin/login.
# AUTH_SECRET=your-random-secret-at-least-32-chars
# One-time seed: ADMIN_SEED_EMAIL=admin@example.com ADMIN_SEED_PASSWORD=... npx tsx scripts/seed-admin.ts
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=...

# Supabase (required for orders + Admin v2 + Partner portal auth)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_DUAL_WRITE_ENABLED=true
# SUPABASE_LOG_LEVEL=info
# Partner portal login (client-side auth). Use same URL as SUPABASE_URL; anon key from Supabase Dashboard → API.
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Sanity (required for catalog and /studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write (required for partner registration and partner bouquet uploads)
# In sanity.io/manage → your project → API → Tokens: create an API token (Editor or Admin).
# Use the project’s API token, not a personal/session token — “project user not found” means the token user isn’t in the project.
SANITY_API_WRITE_TOKEN=your_write_token