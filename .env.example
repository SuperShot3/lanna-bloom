
# Google Tag Manager (client-side). GTM is the only analytics transport and only loads in production.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX   # must match GTM container id exactly, including GTM- prefix
# Optional: defer browser `purchase` until GTM/consent ordering is stable (milliseconds).
# NEXT_PUBLIC_ANALYTICS_PURCHASE_DEFER_MS=120
# NEXT_PUBLIC_ANALYTICS_PURCHASE_GTM_POLL_MAX_MS=2500
# NEXT_PUBLIC_ANALYTICS_PURCHASE_GTM_POLL_INTERVAL_MS=50

# Microsoft Clarity (session replay / heatmaps). Only loads in production when set.
# NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# Google Maps API key (optional). Used for static map previews or driver tooling if enabled.
# Checkout uses manual address + pasted Google Maps share links — no Places autocomplete.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# LINE contact button (website only):
# Set NEXT_PUBLIC_LINE_OA_ADD_FRIEND_LINK to your shareable LINE link.
# NEXT_PUBLIC_LINE_OA_ADD_FRIEND_LINK=https://line.me/ti/p/xxxx

# App URL for the order details link sent in chat (e.g. WhatsApp). Set to your live site URL (e.g. custom domain). If unset on Vercel, the link uses VERCEL_URL (*.vercel.app). Required so the link works when the user clicks it.
# NEXT_PUBLIC_APP_URL=https://www.your-shop.com

# Neutral supplier task links (Admin > Supplier requests). Optional override.
# On Vercel, if unset, links use VERCEL_URL (this deployment's *.vercel.app host), not your custom shop domain
# (Vercel's VERCEL_PROJECT_PRODUCTION_URL prefers the shortest production custom domain). Set this when you need
# a fixed neutral hostname (e.g. https://flower-task-cm.vercel.app) or when VERCEL_URL is unavailable.
# SUPPLIER_REQUEST_BASE_URL=https://flower-task-cm.vercel.app

# Orders: Supabase is single source of truth. See docs/ORDERS_SUPABASE.md
# ORDERS_PRIMARY_STORE=supabase   (default when Supabase configured)
# ORDERS_READ_FALLBACK=none      (default: no Blob fallback)

# Blob: only if ORDERS_READ_FALLBACK=blob (legacy migration fallback)
# BLOB_READ_WRITE_TOKEN=...

# Order notification email (Resend). Add domain lannabloom.shop in Resend, set SPF/DKIM in Porkbun, then use From: orders@lannabloom.shop.
# RESEND_API_KEY=re_xxxx
# ORDERS_NOTIFY_EMAIL=polovnikov.k.v@gmail.com
# Optional: extra recipients for new-order / rich admin emails only (comma-separated).
# ORDERS_NOTIFY_EMAIL_CC=worapanaday@gmail.com
# ORDERS_FROM_EMAIL=Lanna Bloom Orders <orders@lannabloom.shop>
# Trustpilot: BCC on order_delivered customer email only (Automatic Invitation Service address from Trustpilot).
# TRUSTPILOT_INVITE_BCC=lannabloom.shop+490cdcc44b@invite.trustpilot.com

# Emails: brand logo in templates ({{brand_header}} / {{logo_url}}). Defaults to /favicon_io/apple-touch-icon.png under NEXT_PUBLIC_APP_URL.
# Use a public PNG URL (your domain or CDN) so preview + Resend can load the image.
# EMAIL_BRAND_LOGO_URL=https://lannabloom.shop/favicon_io/apple-touch-icon.png
# Or set path only: EMAIL_BRAND_LOGO_PATH=/logo_icon_64.png

# Newsletter: notification when someone subscribes. Uses RESEND_API_KEY and ORDERS_FROM_EMAIL.
# NEWSLETTER_NOTIFY_EMAIL=your@email.com   (recipient; can be same as ORDERS_NOTIFY_EMAIL)

# Stripe (optional). Same env var names are used in test and live; only the VALUES change per Vercel environment.
# For local webhook testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Use the test webhook secret from `stripe listen` locally, and the real endpoint secret from the Stripe Dashboard on Vercel.
# STRIPE_SECRET_KEY=sk_test_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Admin (RBAC with NextAuth). Required for /admin/login.
# AUTH_SECRET=your-random-secret-at-least-32-chars
# One-time seed: ADMIN_SEED_EMAIL=admin@example.com ADMIN_SEED_PASSWORD=... npx tsx scripts/seed-admin.ts
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=...

# Supabase (required for orders, admin, catalog)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_DUAL_WRITE_ENABLED=true
# SUPABASE_LOG_LEVEL=info

# Catalog: Supabase is the default read/write source (bouquets, products, partners, site settings).
# Prerequisite: run catalog migrations + `npm run import-catalog` before first deploy.
# CATALOG_READ_SOURCE=supabase   (default when unset — set to `sanity` only blocks reads; Sanity code removed)
# CATALOG_WRITE_SOURCE=supabase  (default when unset — set to `sanity` only blocks writes; Sanity code removed)
# Product images live in Supabase Storage bucket `catalog` (see supabase/migrations/*catalog_storage*).

# Partner application form (optional client auth for legacy flows; portal retired).
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Accounting: when true, bank/QR manual “mark paid” does not auto-create income — add from Accounting → Income.
# ACCOUNTING_MANUAL_PAID_INCOME_DEFERRED=true

# Deprecated — only for one-time `npm run import-catalog` from Sanity (scripts/archive/; needs devDeps @sanity/client).
# NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_WRITE_TOKEN=your_write_token